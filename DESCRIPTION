Package: testflow
Title: A Workflow Grammar for Statistical Testing, Interpretation, and Visualization
Version: 0.8.2
Authors@R: c(
    person(
      given = "Imad",
      family = "EL BADISY",
      role = c("aut", "cre"),
      email = "elbadisyimad@gmail.com"
    )
